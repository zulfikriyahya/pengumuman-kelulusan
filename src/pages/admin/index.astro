    const pageBtn = (n) => `
      <button onclick="goTestimoniPage(${n})"
        class="w-8 h-8 rounded-lg text-xs font-medium transition
          ${n === testimoniPage ? "bg-indigo-600 text-white" : "bg-slate-700 hover:bg-slate-600 text-slate-300"}">
        ${n}
      </button>`;

    const pageButtons = () => {
      const btns  = [];
      const delta = 2;
      const left  = Math.max(1, testimoniPage - delta);
      const right = Math.min(totalPages, testimoniPage + delta);
      if (left > 1) {
        btns.push(pageBtn(1));
        if (left > 2) btns.push(`<span class="px-1 text-slate-500">...</span>`);
      }
      for (let i = left; i <= right; i++) btns.push(pageBtn(i));
      if (right < totalPages) {
        if (right < totalPages - 1) btns.push(`<span class="px-1 text-slate-500">...</span>`);
        btns.push(pageBtn(totalPages));
      }
      return btns.join("");
    };

    container.innerHTML = `
      <div class="flex flex-wrap items-center justify-between gap-3 mt-3 text-sm">
        <div class="flex items-center gap-2 text-slate-400 text-xs">
          <span>Tampilkan</span>
          <select onchange="changeTestimoniLimit(this.value)"
            class="bg-slate-800 border border-white/10 rounded-lg px-2 py-1 text-xs">
            ${[5, 10, 25, 50, 100].map((n) => `<option value="${n}" ${n === testimoniLimit ? "selected" : ""}>${n}</option>`).join("")}
          </select>
          <span>per halaman · ${total ? `${start}–${end} dari ${total}` : "0 data"}</span>
        </div>
        <div class="flex items-center gap-1">
          <button onclick="goTestimoniPage(${testimoniPage - 1})" ${testimoniPage === 1 ? "disabled" : ""}
            class="w-8 h-8 rounded-lg bg-slate-700 hover:bg-slate-600 disabled:opacity-30 disabled:cursor-not-allowed text-xs transition">‹</button>
          ${pageButtons()}
          <button onclick="goTestimoniPage(${testimoniPage + 1})" ${testimoniPage === totalPages ? "disabled" : ""}
            class="w-8 h-8 rounded-lg bg-slate-700 hover:bg-slate-600 disabled:opacity-30 disabled:cursor-not-allowed text-xs transition">›</button>
        </div>
      </div>`;
  }

  window.goTestimoniPage = (n) => {
    const totalPages = Math.ceil(testimoniData.length / testimoniLimit);
    if (n < 1 || n > totalPages) return;
    testimoniPage = n;
    renderTestimoniList();
  };

  window.changeTestimoniLimit = (val) => {
    testimoniLimit = parseInt(val);
    testimoniPage  = 1;
    renderTestimoniList();
  };

  window.approveTestimoni = async (ids, approved) => {
    const res = await fetch(`${TESTIMONI_URL}?action=approve`, {
      method:      "POST",
      credentials: "include",
      body:        JSON.stringify({ ids, is_approved: approved }),
    });
    const j = await res.json();
    if (j.status === "success") {
      toast(approved ? `${ids.length} testimoni diapprove` : `${ids.length} testimoni dibatalkan`);
      loadTestimoni();
    } else toast(j.message, false);
  };

  window.toggleSelectTestimoni = (id) => {
    if (testimoniSelected.has(id)) testimoniSelected.delete(id);
    else testimoniSelected.add(id);
    updateBulkButtons();
  };

  function updateBulkButtons() {
    const has = testimoniSelected.size > 0;
    document.getElementById("btnBulkDeleteTestimoni").classList.toggle("hidden", !has);
    document.getElementById("btnBulkApproveTestimoni").classList.toggle("hidden", !has);
    const count = document.getElementById("testimoniSelectedCount");
    count.classList.toggle("hidden", !has);
    if (has) count.textContent = `${testimoniSelected.size} dipilih`;
  }

  window.openEditTestimoni = (id, nama, isi) => {
    editTestimoniId = id;
    document.getElementById("etNama").value = nama;
    document.getElementById("etIsi").value  = isi;
    document.getElementById("modalTestimoni").classList.remove("hidden");
  };

  async function simpanTestimoni() {
    const nama = document.getElementById("etNama").value.trim();
    const isi  = document.getElementById("etIsi").value.trim();
    if (!nama || !isi) { toast("Nama dan isi wajib diisi", false); return; }

    const res = await fetch(`${TESTIMONI_URL}?id=${editTestimoniId}`, {
      method:      "PUT",
      credentials: "include",
      body:        JSON.stringify({ nama, isi }),
    });
    const j = await res.json();
    if (j.status === "success") {
      document.getElementById("modalTestimoni").classList.add("hidden");
      toast("Testimoni diperbarui");
      loadTestimoni();
    } else toast(j.message, false);
  }

  async function bulkDeleteTestimoni() {
    if (!confirm(`Hapus ${testimoniSelected.size} testimoni terpilih?`)) return;
    const res = await fetch(`${TESTIMONI_URL}?action=bulk-delete`, {
      method:      "POST",
      credentials: "include",
      body:        JSON.stringify({ ids: [...testimoniSelected] }),
    });
    const j = await res.json();
    if (j.status === "success") {
      toast(`${j.data.deleted} testimoni dihapus`);
      loadTestimoni();
    } else toast(j.message, false);
  }

  window.hapusTestimoni = async (id) => {
    if (!confirm("Hapus testimoni?")) return;
    await fetch(`${TESTIMONI_URL}?id=${id}`, { method: "DELETE", credentials: "include" });
    toast("Testimoni dihapus");
    loadTestimoni();
  };

  // ---- INFORMASI ----
  let editInfoId = null;

  async function loadInformasi() {
    const res  = await fetch(INFO_URL, { credentials: "include" });
    const j    = await res.json();
    const list = document.getElementById("infoList");

    list.innerHTML = (j.data ?? []).map((d) => `
      <div class="bg-slate-800/60 border border-white/10 rounded-2xl p-4 flex gap-4">
        ${d.foto_path ? `<img src="${resolveImgUrl(d.foto_path)}" class="w-20 h-20 rounded-xl object-cover flex-shrink-0" loading="lazy" />` : ""}
        <div class="flex-1 min-w-0">
          <div class="flex items-start justify-between gap-2 mb-1">
            <p class="font-semibold text-sm">${d.judul}</p>
            <span class="text-[10px] px-2 py-0.5 rounded-full flex-shrink-0
              ${d.is_published ? "bg-emerald-500/20 text-emerald-300" : "bg-slate-600 text-slate-400"}">
              ${d.is_published ? "Publik" : "Draft"}
            </span>
          </div>
          ${d.isi ? `<p class="text-slate-400 text-xs line-clamp-2 mb-1">${d.isi}</p>` : ""}
          <div class="flex flex-wrap gap-3 mt-2">
            ${d.file_path ? `<a href="${d.file_path}" target="_blank" class="text-xs text-indigo-400 hover:underline">📎 ${d.file_name ?? "File"}</a>` : ""}
            ${d.link_eksternal ? `<a href="${d.link_eksternal}" target="_blank" class="text-xs text-indigo-400 hover:underline">🔗 Link</a>` : ""}
            <span class="text-slate-500 text-xs">
              ${new Date(d.created_at).toLocaleDateString("id-ID", { day: "numeric", month: "short", year: "numeric" })}
            </span>
          </div>
        </div>
        <div class="flex flex-col gap-2 flex-shrink-0">
          <button onclick="editInfo(${d.id}, ${JSON.stringify(d).replace(/"/g, "&quot;")})"
            class="text-xs text-indigo-400 hover:text-indigo-300">Edit</button>
          <button onclick="hapusInfo(${d.id})"
            class="text-xs text-red-400 hover:text-red-300">Hapus</button>
        </div>
      </div>
    `).join("") || '<p class="text-slate-500 text-sm">Belum ada informasi.</p>';
  }

  function openModalInfo(reset = true) {
    if (reset) {
      editInfoId = null;
      document.getElementById("modalInfoTitle").textContent = "Tambah Informasi";
      document.getElementById("iJudul").value        = "";
      document.getElementById("iIsi").value          = "";
      document.getElementById("iFoto").value         = "";
      document.getElementById("iFotoCaption").value  = "";
      document.getElementById("iFile").value         = "";
      document.getElementById("iLink").value         = "";
      document.getElementById("iPublished").checked  = true;
    }
    document.getElementById("modalInfo").classList.remove("hidden");
  }

  window.editInfo = (id, data) => {
    editInfoId = id;
    document.getElementById("modalInfoTitle").textContent  = "Edit Informasi";
    document.getElementById("iJudul").value                = data.judul ?? "";
    document.getElementById("iIsi").value                  = data.isi ?? "";
    document.getElementById("iFotoCaption").value          = data.foto_caption ?? "";
    document.getElementById("iLink").value                 = data.link_eksternal ?? "";
    document.getElementById("iPublished").checked          = !!data.is_published;
    openModalInfo(false);
  };

  async function simpanInfo() {
    const judul = document.getElementById("iJudul").value.trim();
    if (!judul) { toast("Judul wajib diisi", false); return; }

    if (editInfoId) {
      const body = {
        judul,
        isi:             document.getElementById("iIsi").value.trim(),
        foto_caption:    document.getElementById("iFotoCaption").value.trim(),
        link_eksternal:  document.getElementById("iLink").value.trim(),
        is_published:    document.getElementById("iPublished").checked ? 1 : 0,
      };
      const res = await fetch(`${INFO_URL}?id=${editInfoId}`, {
        method:      "PUT",
        credentials: "include",
        body:        JSON.stringify(body),
      });
      const j = await res.json();
      if (j.status === "success") {
        document.getElementById("modalInfo").classList.add("hidden");
        toast("Informasi diperbarui");
        loadInformasi();
      } else toast(j.message, false);
      return;
    }

    const fd = new FormData();
    fd.append("judul",          judul);
    fd.append("isi",            document.getElementById("iIsi").value.trim());
    fd.append("foto_caption",   document.getElementById("iFotoCaption").value.trim());
    fd.append("link_eksternal", document.getElementById("iLink").value.trim());
    fd.append("is_published",   document.getElementById("iPublished").checked ? "1" : "0");
    const foto = document.getElementById("iFoto").files[0];
    const file = document.getElementById("iFile").files[0];
    if (foto) fd.append("foto", foto);
    if (file) fd.append("file", file);

    const res = await fetch(INFO_URL, { method: "POST", credentials: "include", body: fd });
    const j   = await res.json();
    if (j.status === "success") {
      document.getElementById("modalInfo").classList.add("hidden");
      toast("Informasi ditambahkan");
      loadInformasi();
    } else toast(j.message, false);
  }

  window.hapusInfo = async (id) => {
    if (!confirm("Hapus informasi ini?")) return;
    const res = await fetch(`${INFO_URL}?id=${id}`, { method: "DELETE", credentials: "include" });
    const j   = await res.json();
    if (j.status === "success") {
      toast("Informasi dihapus");
      loadInformasi();
    } else toast(j.message, false);
  };

  // ---- INIT ----
  (async () => {
    const authed = await checkAuth();
    if (authed) showDashboard();

    document.getElementById("btnLogin").onclick = login;
    document.getElementById("loginPass").addEventListener("keydown", (e) => {
      if (e.key === "Enter") login();
    });
    document.getElementById("btnLogout").onclick = logout;

    document.getElementById("btnTambahSiswa").onclick    = () => openModalSiswa();
    document.getElementById("btnSimpanSiswa").onclick    = simpanSiswa;
    document.getElementById("btnBatalSiswa").onclick     = () => document.getElementById("modalSiswa").classList.add("hidden");
    document.getElementById("btnHapusSemua").onclick     = openModalHapusSemua;
    document.getElementById("btnKonfirmasiHapusSemua").onclick = hapusSemua;
    document.getElementById("btnBatalHapusSemua").onclick = () => document.getElementById("modalHapusSemua").classList.add("hidden");

    document.getElementById("konfirmasiHapus").addEventListener("input", (e) => {
      document.getElementById("btnKonfirmasiHapusSemua").disabled = e.target.value !== "HAPUS";
    });

    document.getElementById("csvInput").onchange = (e) => {
      if (e.target.files[0]) handleCSV(e.target.files[0]);
    };

    ["searchSiswa", "filterKelas", "filterJK", "filterStatus", "filterTP"].forEach((id) => {
      const el = document.getElementById(id);
      el.addEventListener("input",  loadSiswa);
      el.addEventListener("change", loadSiswa);
    });

    document.getElementById("btnSavePengumuman").onclick = savePengumuman;
    document.getElementById("btnToggleAktif").addEventListener("click", () => setToggle(!pengumumanAktif));

    document.getElementById("btnUploadAlbum").onclick = uploadAlbum;

    document.getElementById("btnTambahGuru").onclick = () => {
      editGuruId = null;
      document.getElementById("modalGuruTitle").textContent = "Tambah Guru / Pegawai";
      document.getElementById("gNama").value    = "";
      document.getElementById("gJabatan").value = "";
      document.getElementById("gKesan").value   = "";
      document.getElementById("gFoto").value    = "";
      document.getElementById("modalGuru").classList.remove("hidden");
    };
    document.getElementById("btnImportGuru").onclick     = openImportGuru;
    document.getElementById("btnSimpanGuru").onclick     = simpanGuru;
    document.getElementById("btnBatalGuru").onclick      = () => document.getElementById("modalGuru").classList.add("hidden");
    document.getElementById("btnTambahRowGuru").onclick  = addImportRow;
    document.getElementById("btnKirimImportGuru").onclick = kirimImportGuru;
    document.getElementById("btnBatalImportGuru").onclick = () => document.getElementById("modalImportGuru").classList.add("hidden");

    document.getElementById("btnBulkDeleteTestimoni").onclick  = bulkDeleteTestimoni;
    document.getElementById("btnBulkApproveTestimoni").onclick = () => approveTestimoni([...testimoniSelected], 1);
    document.getElementById("btnSimpanTestimoni").onclick      = simpanTestimoni;
    document.getElementById("btnBatalTestimoni").onclick       = () => document.getElementById("modalTestimoni").classList.add("hidden");

    document.getElementById("searchTestimoni").addEventListener("input", (e) => { testimoniQ = e.target.value; loadTestimoni(); });
    document.getElementById("sortTestimoni").addEventListener("change",  (e) => { testimoniSort = e.target.value; loadTestimoni(); });
    document.getElementById("filterTestimoni").addEventListener("change", (e) => { testimoniFilter = e.target.value; loadTestimoni(); });

    document.getElementById("btnTambahInfo").onclick = () => openModalInfo();
    document.getElementById("btnSimpanInfo").onclick = simpanInfo;
    document.getElementById("btnBatalInfo").onclick  = () => document.getElementById("modalInfo").classList.add("hidden");
  })();
</script>
